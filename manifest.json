{
    "manifest_version": 3,
    "name": "SimPli",
    "version": "1.0.0",
    "description": "심플한 나만의 플레이리스트 & 백그라운드 오디오 플레이어",
    "permissions": [
        "storage",
        "offscreen",
        "declarativeNetRequest",
        "scripting"
    ],
    "host_permissions": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.googlevideo.com/*",
        "https://www.googleapis.com/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "youtube_rules",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch*"
            ],
            "js": [
                "js/content.js"
            ],
            "all_frames": true,
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "html/popup.html"
    },
    "background": {
        "service_worker": "js/background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://*.youtube.com https://*.youtube-nocookie.com https://*.googlevideo.com"
    }
}